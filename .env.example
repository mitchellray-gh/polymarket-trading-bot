# ─── Polymarket Trading Engine ─── .env.example ───────────────────────────────
# Copy this file to .env and fill in your secrets.
# NEVER commit the real .env file to version control.

# ─── Wallet Credentials ────────────────────────────────────────────────────────
# Your wallet private key (EVM hex string, no 0x prefix required)
PRIVATE_KEY=your_private_key_here

# The address that HOLDS your funds on Polymarket.
# - EOA (MetaMask): same as the address derived from PRIVATE_KEY
# - Email/Magic/Proxy wallet: the proxy contract address shown in your Polymarket profile
FUNDER_ADDRESS=your_funder_address_here

# ─── Network ────────────────────────────────────────────────────────────────────
# 137 = Polygon Mainnet (live trading), 80002 = Amoy Testnet (paper trading)
CHAIN_ID=137

# Signature type:
#   0 = EOA / MetaMask (private key directly controls funds)
#   1 = Email / Magic wallet (delegated signing)
#   2 = Browser wallet proxy / smart-contract wallet
SIGNATURE_TYPE=0

# ─── Risk & Position Limits ─────────────────────────────────────────────────────
# Maximum USDC to deploy per single trade leg
MAX_POSITION_SIZE_USDC=50

# Minimum net profit (in USDC cents) required before firing a trade
# e.g. 0.005 = 0.5 cents on a $1 outcome — covers gas + fees
MIN_PROFIT_THRESHOLD=0.005

# Maximum number of simultaneous open positions
MAX_OPEN_POSITIONS=10

# ─── Engine Behaviour ───────────────────────────────────────────────────────────
# How often (seconds) to re-scan all markets for opportunities
# 0.5s is the fastest recommended rate; go lower only on co-located infra
SCAN_INTERVAL_SECONDS=0.5

# Tokens per POST /books batch call (max 500 per Polymarket CLOB limits)
SCAN_BATCH_SIZE=500

# Dry-run mode — set to true to log opportunities WITHOUT placing real orders
DRY_RUN=true

# ─── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=trading_engine.log
